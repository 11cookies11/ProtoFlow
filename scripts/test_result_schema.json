{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://protoflow.local/schemas/test_result_schema.json",
  "title": "ProtoFlow Regression Result",
  "type": "object",
  "required": ["suite", "ok", "generated_at", "cases"],
  "properties": {
    "suite": { "type": "string", "minLength": 1 },
    "ok": { "type": "boolean" },
    "generated_at": { "type": "number" },
    "artifacts_dir": { "type": "string" },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "ok", "elapsed_ms"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "ok": { "type": "boolean" },
          "elapsed_ms": { "type": "integer", "minimum": 0 },
          "error_code": { "type": "string" },
          "error_message": { "type": "string" },
          "retry_hit": { "type": "boolean" },
          "metrics": {
            "type": "object",
            "additionalProperties": {
              "type": ["number", "string", "boolean"]
            }
          },
          "logs": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
